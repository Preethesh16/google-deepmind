# Copy this file to server/.env and fill in real values.
# DO NOT COMMIT server/.env

GOOGLE_API_KEY=your_google_api_key_here   # Get a fresh key from aistudio.google.com/api-keys
OLLAMA_URL=http://localhost:11434
GEMMA_MODEL=gemma4:e2b                     # Set to the exact tag you pulled with `ollama pull`
ANTIGRAVITY_MODEL=antigravity-preview-05-2026
FALLBACK_MODEL=gemini-flash-latest             # alias, auto-updates to the current stable Flash model
PORT=3001
VERCEL_TOKEN=                              # From vercel.com/account/tokens (optional)
GENERATED_MVPS_PATH=../generated-mvps
CLIENT_URL=http://localhost:5173

# Sarvam AI — speech-to-text for the voice command bar (kept server-side).
# Get a key at dashboard.sarvam.ai. Never expose this in the client bundle.
SARVAM_API_KEY=
SARVAM_STT_MODEL=saarika:v2

# Fix Center — path to the Excel workbook that holds user feedback.
# Point this at a Google Form → Google Sheets export (.xlsx). A sample
# workbook is auto-seeded here on first run if the file does not exist.
FEEDBACK_XLSX_PATH=feedback.xlsx

# GitHub integration — "Login with GitHub" + push repo + publish to Pages.
# Register a free OAuth App at github.com/settings/developers with
# Authorization callback URL = http://localhost:3001/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/github/callback
# If you'd rather skip OAuth App registration, users can instead paste a
# Personal Access Token (repo scope) via the "Connect with token" option —
# no server env vars needed for that path.
